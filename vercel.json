{
  "version": 2,
  "builds": [
    { "src": "api/config.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/config.js",                    "dest": "/api/config.js" },
    { "src": "/js/(.*)",                       "dest": "/frontend/js/$1" },
    { "src": "/css/(.*)",                      "dest": "/frontend/css/$1" },
    { "src": "/assets/(.*)",                   "dest": "/frontend/assets/$1" },
    { "src": "/org-portal.html",               "dest": "/frontend/org-portal.html" },
    { "src": "/lab-portal.html",               "dest": "/frontend/lab-portal.html" },
    { "src": "/reg-portal.html",               "dest": "/frontend/reg-portal.html" },
    { "src": "/portal-select.html",            "dest": "/frontend/portal-select.html" },
    { "src": "/eco-bot-workspace.html",        "dest": "/frontend/eco-bot-workspace.html" },
    { "src": "/(.*\\.html)",                   "dest": "/frontend/$1" },
    { "src": "/",                              "dest": "/frontend/index.html" },
    { "src": "/(.*)",                          "dest": "/frontend/$1" }
  ]
}
