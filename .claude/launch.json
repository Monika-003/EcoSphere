{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "EcoSphere",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "backend",
      "port": 5000
    },
    {
      "name": "EcoSphere-Static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-l", "3000"],
      "port": 3000
    },
    {
      "name": "EcoSphere-Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-l", "3001"],
      "port": 3001
    }
  ]
}
