# ════════════════════════════════════════════════════════
#  EcoSphere Backend — Local Development Environment
#  ⚠  Never commit this file to git.
# ════════════════════════════════════════════════════════

# --- App ---
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5000
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────
#  DATABASE  (PostgreSQL required)
#
#  Option A — Local PostgreSQL (after installing from postgresql.org):
#    DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/ecosphere_db"
#
#  Option B — Neon free cloud DB (no install needed):
#    1. Go to https://neon.tech  →  Sign up free
#    2. Create project "ecosphere"
#    3. Copy the connection string and paste it below
#
#  Option C — Docker one-liner:
#    docker run --name eco-pg -e POSTGRES_PASSWORD=ecopass -p 5432:5432 -d postgres:15
#    Then use: postgresql://postgres:ecopass@localhost:5432/ecosphere_db
# ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecosphere_db?schema=public"

# ─────────────────────────────────────────────────────────
#  REDIS  (optional in dev — server starts without it)
#
#  Option A — Local Redis (Windows port: https://github.com/tporadowski/redis/releases)
#  Option B — Upstash free cloud: https://upstash.com  →  paste the redis:// URL below
#  Option C — Docker: docker run --name eco-redis -p 6379:6379 -d redis:7
# ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# --- JWT (change these in production!) ---
JWT_SECRET=ecosphere_dev_access_secret_key_minimum_64_characters_long_2025_platform
JWT_ACCESS_SECRET=ecosphere_dev_access_secret_key_minimum_64_characters_long_2025_platform
JWT_REFRESH_SECRET=ecosphere_dev_refresh_secret_key_minimum_64_characters_long_2025_platform
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=ecosphere-api
JWT_AUDIENCE=ecosphere-client

# --- Password ---
BCRYPT_ROUNDS=10

# --- Certificate ---
CERT_SECRET=ecosphere_cert_verification_secret_key_2025

# --- AWS S3 (leave blank to store reports locally in dev) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# --- Email (leave blank to skip emails in dev) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=EcoSphere Dev
EMAIL_FROM=noreply@localhost

# --- SMS Twilio (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# --- OpenAI EcoBot (optional — fallback responses work without it) ---
OPENAI_API_KEY=
ENABLE_AI_ANALYSIS=false

# --- Razorpay (optional — mock orders work without it) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3456,http://localhost:5500,http://127.0.0.1:5500,http://127.0.0.1:3456

# --- Feature flags ---
ENABLE_ECOBOT_AI=false
ENABLE_IOT_INTEGRATION=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_SUBSCRIPTION_BILLING=true
