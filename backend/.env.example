# ════════════════════════════════════════════════════════
#  EcoSphere Backend — Environment Configuration
# ════════════════════════════════════════════════════════

# --- App ---
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3456
LOG_LEVEL=debug

# --- Database (PostgreSQL via Prisma) ---
DATABASE_URL="postgresql://ecosphere_user:strong_password@localhost:5432/ecosphere_db?schema=public"
DATABASE_URL_REPLICA="postgresql://ecosphere_user:strong_password@localhost:5432/ecosphere_db?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_ACCESS_SECRET=your_super_secret_access_token_key_min_64_chars_long_ecosphere_2025
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_min_64_chars_long_ecosphere_2025
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=ecosphere.platform
JWT_AUDIENCE=ecosphere.users

# --- Password ---
BCRYPT_ROUNDS=12

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ecosphere-documents-prod
AWS_S3_BUCKET_PUBLIC=ecosphere-public-assets
AWS_CLOUDFRONT_URL=https://cdn.ecosphere.in

# --- Email (Nodemailer / SES) ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@ecosphere.in
SMTP_PASS=your_email_password
EMAIL_FROM=EcoSphere <notifications@ecosphere.in>
EMAIL_FROM_NAME=EcoSphere Environmental Platform

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- OpenAI (EcoBot AI) ---
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.3

# --- Payment (Razorpay) ---
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# --- Monitoring ---
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# --- QR Code ---
QR_BASE_URL=https://verify.ecosphere.in/certificate

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3456,https://ecosphere.in,https://www.ecosphere.in

# --- Session ---
SESSION_SECRET=your_session_secret_min_64_chars_ecosphere_platform_2025

# --- Feature Flags ---
ENABLE_ECOBOT_AI=true
ENABLE_IOT_INTEGRATION=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_WHATSAPP_NOTIFICATIONS=false
ENABLE_SUBSCRIPTION_BILLING=true
