  prevYearSocial        Decimal?         @db.Decimal(6, 2)
  prevYearGov           Decimal?         @db.Decimal(6, 2)
  prevYearOverall       Decimal?         @db.Decimal(6, 2)
  envTrend              EsgScoreTrend?
  socialTrend           EsgScoreTrend?
  govTrend              EsgScoreTrend?
  overallTrend          EsgScoreTrend?
  yoyOverallChangePts   Decimal?         @db.Decimal(6, 2)   // Positive = improved

  // ── Materiality
  materialTopics        String[]         // Top material topics for this period
  reportingGaps         String[]         // Missing / insufficient data areas

  // ── Computation Metadata
  computedAt            DateTime?
  computedByModel       String?          // "rules-engine-v2" | "openai-gpt4o"
  scoringVersion        String?          // Schema version used for scoring

  notes                 String?          @db.Text

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([organizationId, reportingYear])
  @@index([organizationId])
  @@index([reportingYear])
  @@map("esg_scores")
}

// ─────────────────────────────────────────────────────────────────
//  13. ESG REPORT HISTORY
//  Each generated ESG report stored with scores snapshot
// ─────────────────────────────────────────────────────────────────

model EsgReportHistory {
  id                    String            @id @default(uuid())
  organizationId        String
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportingYear         String
  periodFrom            DateTime
  periodTo              DateTime

  // ── Report Identity
  reportFormat          EsgReportFormat   @default(CUSTOM)
  reportTitle           String?
  templateVersion       String?           // e.g. "v3.1"
  reportLanguage        String            @default("en")

  // ── Generation
  generatedById         String?           // User.id (no FK constraint)
  generatedAt           DateTime          @default(now())
  generationDurationMs  Int?

  // ── Storage
  s3Key                 String?
  s3Bucket              String?
  fileName              String?
  fileSizeBytes         Int?
  mimeType              String            @default("application/pdf")

  // ── Scores Snapshot at Time of Generation
  envScoreSnapshot      Decimal?          @db.Decimal(6, 2)
  socialScoreSnapshot   Decimal?          @db.Decimal(6, 2)
  govScoreSnapshot      Decimal?          @db.Decimal(6, 2)
  overallScoreSnapshot  Decimal?          @db.Decimal(6, 2)
  esgRatingSnapshot     EsgScoreRating?

  // ── Data Sections Included
  sectionsIncluded      EsgSection[]      // Sections included in this report

  // ── Lifecycle
  status                EsgHistoryStatus  @default(GENERATED)
  sharedWith            String[]          // Email addresses shared with
  sharedAt              DateTime?
  accessCount           Int               @default(0)
  lastAccessedAt        DateTime?
  archivedAt            DateTime?

  notes                 String?           @db.Text

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([organizationId])
  @@index([organizationId, reportingYear])
  @@index([reportingYear])
  @@index([generatedAt])
  @@map("esg_report_history")
}

// ═══════════════════════════════════════════════════════════════════
//  EIA MODULE — Environmental Impact Assessment
//  Phase 6 | 10 modules linked to EiaProject per organization
// ═══════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────────

enum EiaProjectStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  APPROVED
  REJECTED
  CLOSED
}

enum EiaProjectType {
  GREENFIELD
  BROWNFIELD
  EXPANSION
  MODERNISATION
  DECOMMISSIONING
}

enum EiaProjectCategory {
  CATEGORY_A
  CATEGORY_B1
  CATEGORY_B2
}

enum EiaMonitoringFrequency {
  DAILY
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUALLY
}

enum EiaImpactSignificance {
  NEGLIGIBLE
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

enum EiaImpactType {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum EiaImpactDuration {
  SHORT_TERM
  MEDIUM_TERM
  LONG_TERM
  PERMANENT
}

enum EiaMitigationStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  NOT_APPLICABLE
  DEFERRED
}

enum EiaReportStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum EiaReportType {
  BASELINE
  MONITORING
  COMPLIANCE
  HALF_YEARLY
  ANNUAL
  FINAL_EIA
  CLOSURE
}

// ─────────────────────────────────────────────────────────────────
//  1. EIA PROJECT  (root entity — all modules link here)
// ─────────────────────────────────────────────────────────────────

model EiaProject {
  id                   String             @id @default(cuid())
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Identity
  projectName          String
  projectNumber        String?
  projectType          EiaProjectType
  projectCategory      EiaProjectCategory
  status               EiaProjectStatus   @default(DRAFT)
  description          String?            @db.Text
  industry             String?
  activity             String?            // Activity / product as per Schedule of EIA Notification

  // Location
  location             String?
  state                String?
  district             String?
  village              String?
  latitude             Decimal?           @db.Decimal(10, 8)
  longitude            Decimal?           @db.Decimal(11, 8)
  areaHectares         Decimal?           @db.Decimal(12, 4)

  // Financial
  investmentCrores     Decimal?           @db.Decimal(15, 2)
  proposedCapacity     String?

  // Proponent & Consultant
  projectProponent     String?
  consultantName       String?
  consultantAccNo      String?            // NABET / QCI accreditation number

  // Regulatory clearances
  eiaNotificationYear  String?
  tocGranted           Boolean            @default(false)
  tocDate              DateTime?
  ecGranted            Boolean            @default(false)
  ecDate               DateTime?
  ecNumber             String?
  ecIssuingAuthority   String?            // MoEFCC | SEIAA | DEIAA
  cteGranted           Boolean            @default(false)  // Consent to Establish
  cteNumber            String?
  ctoGranted           Boolean            @default(false)  // Consent to Operate
  ctoNumber            String?

  // Public Hearing
  publicHearingDone    Boolean            @default(false)
  publicHearingDate    DateTime?
  publicHearingVenue   String?

  // Study Period
  studyPeriodFrom      DateTime?
  studyPeriodTo        DateTime?
  reportingYear        String

  createdBy            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Module relations
  airMonitoring        EiaAirMonitoring[]
  waterMonitoring      EiaWaterMonitoring[]
  soilMonitoring       EiaSoilMonitoring[]
  noiseMonitoring      EiaNoiseMonitoring[]
  impactAssessments    EiaImpactAssessment[]
  mitigationMeasures   EiaMitigationMeasure[]
  monitoringProgram    EiaMonitoringProgram?
  evidence             EiaEvidence[]
  reportHistory        EiaReportHistory[]

  @@index([organizationId])
  @@index([organizationId, reportingYear])
  @@index([status])
  @@index([reportingYear])
  @@map("eia_projects")
}

// ─────────────────────────────────────────────────────────────────
//  2. AIR MONITORING
//  Per project — multiple stations, multiple dates
// ─────────────────────────────────────────────────────────────────

model EiaAirMonitoring {
  id               String    @id @default(cuid())
  projectId        String
  project          EiaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Station & date
  stationName      String
  stationCode      String?
  monitoringDate   DateTime
  monitoringPeriod String?   // "24-hour", "8-hour", "4-hour"
  location         String?
  phase            String?   // "PRE_CONSTRUCTION", "CONSTRUCTION", "OPERATION", "POST_OPERATION"

  // Criteria pollutants (μg/m³)
  pm25             Decimal?  @db.Decimal(8, 3)
  pm10             Decimal?  @db.Decimal(8, 3)
  rspm             Decimal?  @db.Decimal(8, 3)   // Respirable SPM
  spm              Decimal?  @db.Decimal(8, 3)   // Total SPM
  so2              Decimal?  @db.Decimal(8, 3)
  nox              Decimal?  @db.Decimal(8, 3)
  no2              Decimal?  @db.Decimal(8, 3)
  co               Decimal?  @db.Decimal(8, 3)   // mg/m³
  o3               Decimal?  @db.Decimal(8, 3)
  nh3              Decimal?  @db.Decimal(8, 3)
  pb               Decimal?  @db.Decimal(8, 3)   // Lead
  benzene          Decimal?  @db.Decimal(8, 3)
  benzoPyrene      Decimal?  @db.Decimal(8, 3)   // Benzo(a)pyrene
  hc               Decimal?  @db.Decimal(8, 3)   // Hydrocarbons

  // Meteorological
  windSpeed        Decimal?  @db.Decimal(6, 2)   // m/s
  windDirection    String?
  temperature      Decimal?  @db.Decimal(5, 2)   // °C
  relHumidity      Decimal?  @db.Decimal(5, 2)   // %
  stability        String?   // Pasquill class A–F

  // CPCB standards (μg/m³)
  pm25Std          Decimal?  @db.Decimal(8, 3)
  pm10Std          Decimal?  @db.Decimal(8, 3)
  so2Std           Decimal?  @db.Decimal(8, 3)
  noxStd           Decimal?  @db.Decimal(8, 3)

  // Exceedance flags
  pm25Exceedance   Boolean   @default(false)
  pm10Exceedance   Boolean   @default(false)
  so2Exceedance    Boolean   @default(false)
  noxExceedance    Boolean   @default(false)
  anyExceedance    Boolean   @default(false)

  labName          String?
  labAccreditation String?
  remarks          String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId])
  @@index([projectId, monitoringDate])
  @@index([anyExceedance])
  @@map("eia_air_monitoring")
}

// ─────────────────────────────────────────────────────────────────
//  3. WATER MONITORING
// ─────────────────────────────────────────────────────────────────

model EiaWaterMonitoring {
  id               String    @id @default(cuid())
  projectId        String
  project          EiaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Source
  sourceType       String    // "SURFACE_WATER" | "GROUNDWATER" | "EFFLUENT" | "DRINKING_WATER" | "RAINWATER"
  sourceName       String
  monitoringDate   DateTime
  location         String?
  depth            Decimal?  @db.Decimal(6, 2)   // metres (groundwater)
  phase            String?

  // Physical parameters
  pH               Decimal?  @db.Decimal(5, 2)
  temperature      Decimal?  @db.Decimal(5, 2)   // °C
  turbidity        Decimal?  @db.Decimal(8, 2)   // NTU
  tds              Decimal?  @db.Decimal(8, 2)   // mg/L
  tss              Decimal?  @db.Decimal(8, 2)   // mg/L
  conductivity     Decimal?  @db.Decimal(8, 2)   // μS/cm
  dissolvedO2      Decimal?  @db.Decimal(6, 2)   // mg/L
  colour           String?

  // Chemical parameters (mg/L)
  bod              Decimal?  @db.Decimal(8, 2)
  cod              Decimal?  @db.Decimal(8, 2)
  hardness         Decimal?  @db.Decimal(8, 2)
  alkalinity       Decimal?  @db.Decimal(8, 2)
  chlorides        Decimal?  @db.Decimal(8, 2)
  sulfates         Decimal?  @db.Decimal(8, 2)
  nitrates         Decimal?  @db.Decimal(8, 2)
  nitrites         Decimal?  @db.Decimal(8, 2)
  phosphates       Decimal?  @db.Decimal(8, 2)
  fluorides        Decimal?  @db.Decimal(8, 2)
  silica           Decimal?  @db.Decimal(8, 2)

  // Heavy metals (mg/L)
  arsenic          Decimal?  @db.Decimal(8, 4)
  cadmium          Decimal?  @db.Decimal(8, 4)
  chromium         Decimal?  @db.Decimal(8, 4)
  copper           Decimal?  @db.Decimal(8, 4)
  iron             Decimal?  @db.Decimal(8, 4)
  lead             Decimal?  @db.Decimal(8, 4)
  manganese        Decimal?  @db.Decimal(8, 4)
  mercury          Decimal?  @db.Decimal(8, 4)
  nickel           Decimal?  @db.Decimal(8, 4)
  zinc             Decimal?  @db.Decimal(8, 4)

  // Biological
  coliformTotal    Decimal?  @db.Decimal(10, 0)  // MPN/100mL
  coliformFecal    Decimal?  @db.Decimal(10, 0)

  // Exceedance
  exceedanceFlag   Boolean   @default(false)
  exceedanceParams String?   // comma-separated params that exceeded limits

  labName          String?
  labAccreditation String?
  remarks          String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId])
  @@index([projectId, monitoringDate])
  @@index([sourceType])
  @@map("eia_water_monitoring")
}

// ─────────────────────────────────────────────────────────────────
//  4. SOIL MONITORING
// ─────────────────────────────────────────────────────────────────

model EiaSoilMonitoring {
  id               String    @id @default(cuid())
  projectId        String
  project          EiaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sampleId         String?
  sampleLocation   String
  monitoringDate   DateTime
  depth            String?   // "0-15cm", "15-30cm", "30-60cm"
  soilType         String?   // "CLAY", "SANDY", "LOAMY", "SILT"
  landUse          String?
  phase            String?

  // Physical properties
  pH               Decimal?  @db.Decimal(5, 2)
  electricalCond   Decimal?  @db.Decimal(8, 3)  // dS/m
  organicCarbon    Decimal?  @db.Decimal(7, 3)  // %
  organicMatter    Decimal?  @db.Decimal(7, 3)  // %
  bulkDensity      Decimal?  @db.Decimal(6, 3)  // g/cm³
  moisture         Decimal?  @db.Decimal(6, 2)  // %
  texture          String?
  waterHolding     Decimal?  @db.Decimal(6, 2)  // %

  // Nutrients (kg/ha or mg/kg)
  nitrogen         Decimal?  @db.Decimal(8, 2)
  phosphorus       Decimal?  @db.Decimal(8, 2)
  potassium        Decimal?  @db.Decimal(8, 2)
  sulfur           Decimal?  @db.Decimal(8, 2)

  // Heavy metals (mg/kg dry weight)
  arsenic          Decimal?  @db.Decimal(8, 3)
  cadmium          Decimal?  @db.Decimal(8, 3)
  chromium         Decimal?  @db.Decimal(8, 3)
  copper           Decimal?  @db.Decimal(8, 3)
  iron             Decimal?  @db.Decimal(8, 3)
  lead             Decimal?  @db.Decimal(8, 3)
  manganese        Decimal?  @db.Decimal(8, 3)
  nickel           Decimal?  @db.Decimal(8, 3)
  zinc             Decimal?  @db.Decimal(8, 3)
  mercury          Decimal?  @db.Decimal(8, 3)

  exceedanceFlag   Boolean   @default(false)
  exceedanceParams String?

  labName          String?
  labAccreditation String?
  remarks          String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId])
  @@index([projectId, monitoringDate])
  @@map("eia_soil_monitoring")
}

// ─────────────────────────────────────────────────────────────────
//  5. NOISE MONITORING
// ─────────────────────────────────────────────────────────────────

model EiaNoiseMonitoring {
  id               String    @id @default(cuid())
  projectId        String
  project          EiaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  locationName     String
  locationType     String?   // "RESIDENTIAL" | "COMMERCIAL" | "INDUSTRIAL" | "SILENCE_ZONE"
  monitoringDate   DateTime
  phase            String?

  // Measurements dB(A)
  dayAvgDb         Decimal?  @db.Decimal(5, 2)  // 6 AM – 10 PM
  nightAvgDb       Decimal?  @db.Decimal(5, 2)  // 10 PM – 6 AM
  dayMinDb         Decimal?  @db.Decimal(5, 2)
  dayMaxDb         Decimal?  @db.Decimal(5, 2)
  nightMinDb       Decimal?  @db.Decimal(5, 2)
  nightMaxDb       Decimal?  @db.Decimal(5, 2)
  leq              Decimal?  @db.Decimal(5, 2)  // Equivalent Continuous Sound Level
  l10              Decimal?  @db.Decimal(5, 2)  // Exceeded for 10% of time
  l50              Decimal?  @db.Decimal(5, 2)  // Exceeded for 50% of time
  l90              Decimal?  @db.Decimal(5, 2)  // Exceeded for 90% of time (background)
  lmax             Decimal?  @db.Decimal(5, 2)  // Maximum
  lmin             Decimal?  @db.Decimal(5, 2)  // Minimum
  ldn              Decimal?  @db.Decimal(5, 2)  // Day-Night Level

  // CPCB / EIA standards (dB(A))
  daytimeStd       Decimal?  @db.Decimal(5, 2)
  nighttimeStd     Decimal?  @db.Decimal(5, 2)

  // Exceedance
  dayExceedance    Boolean   @default(false)
  nightExceedance  Boolean   @default(false)
  anyExceedance    Boolean   @default(false)

  // Instrument
  instrumentModel  String?
  calibrated       Boolean   @default(false)
  calibrationDate  DateTime?

  remarks          String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId])
  @@index([projectId, monitoringDate])
  @@map("eia_noise_monitoring")
}

// ─────────────────────────────────────────────────────────────────
//  6. IMPACT ASSESSMENT
// ─────────────────────────────────────────────────────────────────

model EiaImpactAssessment {
  id               String              @id @default(cuid())
  projectId        String
  project          EiaProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  component        String              // "AIR" | "WATER" | "SOIL" | "NOISE" | "ECOLOGY" | "SOCIOECONOMIC" | "HERITAGE" | "HYDROLOGY"
  impactType       EiaImpactType
  significance     EiaImpactSignificance
  duration         EiaImpactDuration?
  description      String              @db.Text

  reversibility    String?             // "REVERSIBLE" | "IRREVERSIBLE"
  probability      String?             // "LOW" | "MEDIUM" | "HIGH" | "CERTAIN"
  spatialExtent    String?             // "LOCAL" | "REGIONAL" | "NATIONAL" | "TRANSBOUNDARY"
  magnitude        Int?                // 1-10 scale
  sensitivity      Int?                // 1-5 scale (receptor sensitivity)
  significance_score Int?              // magnitude × sensitivity

  // Phase applicability
  constructionPhase Boolean            @default(false)
  operationPhase    Boolean            @default(true)
  decommPhase       Boolean            @default(false)

  // Cumulative impact
  cumulativeImpact  Boolean            @default(false)
  cumulativeDesc    String?            @db.Text

  residualImpact    String?            @db.Text
  mitigationPossible Boolean          @default(true)
  remarks           String?            @db.Text

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  mitigations       EiaMitigationMeasure[]

  @@index([projectId])
  @@index([projectId, component])
  @@index([significance])
  @@map("eia_impact_assessments")
}

// ─────────────────────────────────────────────────────────────────
//  7. MITIGATION MEASURES
// ─────────────────────────────────────────────────────────────────

model EiaMitigationMeasure {
  id               String              @id @default(cuid())
  projectId        String
  project          EiaProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  impactId         String?
  impact           EiaImpactAssessment? @relation(fields: [impactId], references: [id])

  component        String              // "AIR" | "WATER" | "SOIL" | "NOISE" | "ECOLOGY" | "SOCIOECONOMIC" | "WASTE"
  measureTitle     String
  description      String              @db.Text
  measureType      String?             // "PREVENTIVE" | "CONTROL" | "REMEDIAL" | "COMPENSATORY"
  implementedBy    String?             // Responsible party
  timeline         String?             // "Immediate" | "Short-term" | "Long-term"
  estimatedCost    Decimal?            @db.Decimal(12, 2)  // ₹ Lakhs
  status           EiaMitigationStatus @default(PLANNED)

  // KPI tracking
  kpi              String?
  targetValue      String?
  actualValue      String?
  performanceNote  String?             @db.Text

  // Phase
  constructionPhase Boolean            @default(false)
  operationPhase    Boolean            @default(true)
  decommPhase       Boolean            @default(false)

  completionDate   DateTime?
  verifiedBy       String?
  verifiedAt       DateTime?
  remarks          String?             @db.Text

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([projectId])
  @@index([projectId, status])
  @@index([component])
  @@map("eia_mitigation_measures")
}

// ─────────────────────────────────────────────────────────────────
//  8. MONITORING PROGRAM
//  One record per project — schedule and lab details
// ─────────────────────────────────────────────────────────────────

model EiaMonitoringProgram {
  id               String                 @id @default(cuid())
  projectId        String                 @unique
  project          EiaProject             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Air monitoring schedule
  airFrequency     EiaMonitoringFrequency?
  airParameters    String?
  airStationsCount Int?
  airSamplingMethod String?

  // Water monitoring schedule
  waterFrequency   EiaMonitoringFrequency?
  waterParameters  String?
  waterSourcesCount Int?
  waterSamplingMethod String?

  // Soil monitoring schedule
  soilFrequency    EiaMonitoringFrequency?
  soilParameters   String?
  soilLocationsCount Int?

  // Noise monitoring schedule
  noiseFrequency   EiaMonitoringFrequency?
  noiseParameters  String?
  noiseLocationsCount Int?

  // Ecology monitoring
  ecologyMonitoring Boolean            @default(false)
  ecologyFrequency  EiaMonitoringFrequency?
  ecologyParameters String?

  // Accredited Lab
  labName          String?
  labNablNo        String?
  labContact       String?

  // EMC / Environmental Monitoring Consultant
  emcName          String?
  emcAccreditation String?
  emcContact       String?

  // Budget & schedule
  annualBudgetLakhs Decimal?           @db.Decimal(10, 2)
  nextMonitoringDate DateTime?
  lastMonitoringDate DateTime?

  // Compliance
  spcbSubmission   Boolean             @default(false)
  spcbFrequency    EiaMonitoringFrequency?
  moefccSubmission Boolean             @default(false)

  remarks          String?             @db.Text

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@map("eia_monitoring_programs")
}

// ─────────────────────────────────────────────────────────────────
//  9. EVIDENCE MANAGEMENT
// ─────────────────────────────────────────────────────────────────

model EiaEvidence {
  id               String    @id @default(cuid())
  projectId        String
  project          EiaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  module           String    // "air" | "water" | "soil" | "noise" | "impact" | "mitigation" | "general"
  documentType     String?   // "LAB_REPORT" | "SITE_PHOTO" | "MAP" | "CERTIFICATE" | "EC_LETTER" | "OTHER"
  originalName     String
  fileName         String
  mimeType         String
  fileSize         Int?
  s3Key            String
  s3Bucket         String

  description      String?
  tags             String?
  monitoringDate   DateTime?
  uploadedBy       String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId])
  @@index([projectId, module])
  @@map("eia_evidence")
}

// ─────────────────────────────────────────────────────────────────
//  10. REPORT HISTORY
// ─────────────────────────────────────────────────────────────────

model EiaReportHistory {
  id               String          @id @default(cuid())
  projectId        String
  project          EiaProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  reportTitle      String
  reportType       EiaReportType
  reportPeriod     String?         // e.g. "Apr 2024 – Mar 2025"
  reportFormat     String          @default("PDF")
  status           EiaReportStatus @default(DRAFT)

  generatedBy      String?
  generatedAt      DateTime        @default(now())

  // Storage
  s3Key            String?
  s3Bucket         String?
  fileName         String?
  fileSizeBytes    Int?

  // Submission
  submittedTo      String?         // "MoEFCC" | "SPCB" | "DEIAA" | "SEAC"
  submissionDate   DateTime?
  submissionRefNo  String?

  // Approval
  approvalDate     DateTime?
  approvalNumber   String?
  approvedBy       String?

  notes            String?         @db.Text

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([projectId])
  @@index([projectId, reportType])
  @@index([status])
  @@map("eia_report_history")
}
