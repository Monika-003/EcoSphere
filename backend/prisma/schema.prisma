// ─────────────────────────────────────────────────────────────────

model EsgEvidence {
  id                    String           @id @default(uuid())
  organizationId        String
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reportingYear         String
  section               EsgSection       // Which ESG section this belongs to
  fieldReference        String?          // Specific field or metric it evidences

  // ── File Metadata
  fileName              String           // Sanitized filename stored in S3
  originalName          String           // Original user-uploaded filename
  mimeType              String           // "application/pdf" | "image/jpeg" | etc.
  sizeBytes             Int

  // ── S3 Location
  s3Key                 String           // Full S3 object key
  s3Bucket              String
  presignedUrlExpiry    DateTime?        // When current pre-signed URL expires

  // ── Metadata
  description           String?
  tags                  String[]         // Auto + manual tags for search
  uploadedById          String?          // User.id (no FK constraint)

  // ── Verification
  isVerified            Boolean          @default(false)
  verifiedById          String?          // User.id (no FK constraint)
  verifiedAt            DateTime?

  // ── Quality (for PDF report auto-selection)
  qualityScore          Int?             // 1-100: resolution / relevance score
  isCoverImage          Boolean          @default(false)
  displayOrder          Int?             // Order within section evidence gallery

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([organizationId])
  @@index([organizationId, reportingYear])
  @@index([organizationId, section])
  @@index([reportingYear])
  @@map("esg_evidence")
}

