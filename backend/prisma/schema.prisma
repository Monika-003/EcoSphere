  intensityDenomCurr    Decimal?         @db.Decimal(18, 4)
  intensityDenomPrev    Decimal?         @db.Decimal(18, 4)
  wasteIntensityCurr    Decimal?         @db.Decimal(18, 6)
  wasteIntensityPrev    Decimal?         @db.Decimal(18, 6)
